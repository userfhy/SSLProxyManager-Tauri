{
  "name": "SSLProxyManager",
  "version": "1.0.25",
  "description": "SSL 代理管理工具",
  "scripts": {
    "dev": "echo \"No frontend dev server configured. Edit package.json scripts.dev or src-tauri/tauri.conf.json build.beforeDevCommand\" && exit 1",
    "build": "echo \"No frontend build configured. Edit package.json scripts.build or src-tauri/tauri.conf.json build.beforeBuildCommand\" && exit 1",
    "tauri": "tauri",
    "tauri:dev:debug": "RUST_LOG=debug tauri dev --config tauri.conf.json",
    "tauri:dev:info": "RUST_LOG=info tauri dev --config tauri.conf.json",
    "tauri:dev": "tauri dev --config tauri.conf.json",
    "tauri:build": "tauri build --config tauri.conf.json",
    "tauri:build:debug": "RUST_LOG=debug tauri build --config tauri.conf.json",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.17.0",
      "onFail": "download"
    }
  }
}
